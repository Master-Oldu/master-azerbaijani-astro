---
// (unchanged imports)
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import ShareButtons from '../components/ShareButtons.astro';

type Props = CollectionEntry<'blog'>['data'];

const { 
  title,
  description,
  pubDate,
  updatedDate,
  coverImage,
  coverImageAlt,
  author
} = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />

    <style>
      /* EXISTING STYLES (unchanged) */

      .hero-image {
        max-width: 900px;
        margin: 0 auto 40px;
      }

      .hero-image img {
        width: 100%;
        height: auto;
        border-radius: 12px;
        box-shadow: var(--box-shadow);
        display: block;
      }

      @media (min-width: 768px) {
        .hero-image img {
          max-height: 400px;
          object-fit: contain;
        }
      }

      @media (min-width: 1200px) {
        .hero-image img {
          max-height: 480px;
        }
      }

      .post-title-block {
        max-width: 900px;
        margin: 40px auto 40px;
        text-align: center;
      }

      .post-title {
        margin-bottom: 1rem;
        line-height: 1.2;
        font-size: 2.3rem;
        text-align: center;
      }

      .post-meta {
        max-width: 900px;
        margin: 0 auto;
        padding-left: 20px;
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        opacity: 0.85;
        font-size: 0.95rem;
      }

      .blog-content {
        max-width: 900px;
        margin: 50px auto 0;
      }

      .blog-content p {
        margin-bottom: 1.4rem;
        line-height: 1.7;
      }
/**********************************************
 RESTORE BLOG ALIGNMENT (ADD ONLY)
**********************************************/
.page-container.blog-page {
  text-align: left !important;
}

.blog-content {
  text-align: left !important;
}

.blog-content h2,
.blog-content h3,
.blog-content h4 {
  text-align: left !important;
}

.page-container.blog-page .blog-content ul,
.page-container.blog-page .blog-content ol {
  padding-left: 3rem !important;
  list-style-position: outside !important;
}

.page-container.blog-page .blog-content li {
  line-height: 1.7;
}

      /* ===== NEW: REACTIONS ===== */

      .reaction-btn {
        padding: 8px 18px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.25);
        background: transparent;
        color: inherit;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s ease;
      }

      .reaction-btn:hover {
        border-color: #7fd1c3;
        background: rgba(127, 209, 195, 0.08);
      }

      .reaction-btn.active {
        border-color: #7fd1c3;
        background: rgba(127, 209, 195, 0.15);
      }

      .reaction-btn:disabled {
        opacity: 1;
        cursor: default;
      }
    </style>
  </head>

  <body>
    <Header />

    <main class="page-container blog-page">

      <div class="hero-image">
        <img 
          src={coverImage || "/images/alphabet_crop.jpg"} 
          alt={coverImageAlt || title} 
        />
      </div>

      <div class="post-title-block">
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          {author && <div>By {author}</div>}
          <div><FormattedDate date={pubDate} /></div>
        </div>
      </div>

      <hr style="margin: 40px auto; max-width: 900px;" />

      <article class="blog-content">
        <slot />
      </article>

      <!-- REACTIONS -->
      <div style="max-width: 900px; margin: 40px auto 0;">
        <p style="font-size: 14px; opacity: 0.8; margin-bottom: 12px;">
          Was this helpful?
        </p>

        <div style="display: flex; gap: 12px;">
          <button id="like-btn" class="reaction-btn">Yes</button>
          <button id="dislike-btn" class="reaction-btn">No</button>
        </div>

        <div id="reaction-result" style="margin-top: 12px; font-size: 13px; opacity: 0.7; display: none;">
          <span id="like-count">0</span> helpful ·
          <span id="dislike-count">0</span> not helpful
        </div>
      </div>

      <div style="max-width: 900px; margin: 40px auto 0;">
        <ShareButtons title={title} />
      </div>

    </main>

    <Footer />

    <script>
     const postSlug = window.location.pathname
  .replace(/\/$/, "")   // removes trailing slash
  .split("/")           // splits path
  .pop();               // gets last part

      const likeBtn = document.getElementById("like-btn");
      const dislikeBtn = document.getElementById("dislike-btn");
      const resultBox = document.getElementById("reaction-result");

      const likeCount = document.getElementById("like-count");
      const dislikeCount = document.getElementById("dislike-count");
const existingVote = localStorage.getItem("voted_" + postSlug);

if (existingVote) {
  likeBtn.disabled = true;
  dislikeBtn.disabled = true;

  if (existingVote === "like") {
    likeBtn.classList.add("active");
  } else {
    dislikeBtn.classList.add("active");
  }

  // fetch counts so user still sees numbers
  fetch("/.netlify/functions/vote", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: JSON.stringify({
      post_slug: postSlug,
      vote: existingVote,
    }),
  })
    .then(res => res.json())
    .then(data => {
      likeCount.textContent = data.likes;
      dislikeCount.textContent = data.dislikes;
      resultBox.style.display = "block";
    });
}
      async function sendVote(voteType) {
        const res = await fetch("/.netlify/functions/vote", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify({
            post_slug: postSlug,
            vote: voteType,
          }),
        });

        const data = await res.json();

        likeCount.textContent = data.likes;
        dislikeCount.textContent = data.dislikes;

        resultBox.style.display = "block";
resultBox.style.opacity = "0";
resultBox.style.transition = "opacity 0.3s ease";

setTimeout(() => {
  resultBox.style.opacity = "1";
}, 10);

        // FIXED logic
        if (voteType === "like") {
          likeBtn.classList.add("active");
          dislikeBtn.classList.remove("active");
        } else {
          dislikeBtn.classList.add("active");
          likeBtn.classList.remove("active");
        }

        likeBtn.disabled = true;
        dislikeBtn.disabled = true;

        localStorage.setItem("voted_" + postSlug, voteType);
      }

      likeBtn.addEventListener("click", () => sendVote("like"));
      dislikeBtn.addEventListener("click", () => sendVote("dislike"));
    </script>

  </body>
</html>